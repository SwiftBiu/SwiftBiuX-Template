{
  "identifier": "com.SwiftBiu.gemini",
  "name": "Gemini",
  "author": "SwiftBiu",
  "description": "Send the selected text to Google Gemini and get the response.",
  "version": "1.7",
  "actions": [
    {
      "title": "Gemini",
      "script": "script.js",
      "extensionKind": "textAction"
    }
  ],
  "icon": "gemini.png",
  "iconType": "file",
  "permissions": [
    "network",
    "paste",
    "notifications",
    "ui"
  ],
  "configuration": [
    {
      "key": "apikey",
      "label": "Gemini API Key",
      "placeholder": "Enter your Gemini API key",
      "description": "Obtain an API key from Google AI Studio.",
      "type": "secure"
    },
    {
      "key": "apiurl",
      "label": "API URL",
      "type": "string",
      "placeholder": "e.g., https://generativelanguage.googleapis.com/v1beta/models/gemini-3.0-flash-preview:generateContent",
      "description": "Custom Gemini API endpoint. Leave blank for default.",
      "isSecure": false
    },
    {
      "key": "model",
      "label": "Model",
      "type": "option",
      "description": "The model to use.",
      "options": [
        {
          "label": "Gemini 3.1 Pro",
          "value": "gemini-3.1-pro-preview"
        },
        {
          "label": "Gemini 3.1 Flash Lite",
          "value": "gemini-3.1-flash-lite-preview"
        },
        {
          "label": "Gemini 3.0 Pro",
          "value": "gemini-3-pro-preview"
        },
        {
          "label": "Gemini 3.0 Flash",
          "value": "gemini-3-flash-preview"
        },
        {
          "label": "Gemini 2.5 Pro",
          "value": "gemini-2.5-pro"
        },
        {
          "label": "Gemini 2.5 Flash",
          "value": "gemini-2.5-flash"
        },
        {
          "label": "Gemini 2.0 Flash Lite",
          "value": "gemini-2.0-flash-lite"
        },
        {
          "label": "Gemini 2.0 Flash",
          "value": "gemini-2.0-flash"
        },
        {
          "label": "Gemini 2.0 Pro",
          "value": "gemini-2.0-pro"
        },
        {
          "label": "Gemma 3n-e4b-it",
          "value": "gemma-3n-e4b-it"
        }
      ]
    },
    {
      "key": "contextMessageCount",
      "label": "上下文消息数量",
      "type": "string",
      "defaultValue": "0",
      "placeholder": "0-10",
      "description": "设置发送给 AI 的历史消息数量。0 表示不带上下文，最高可设置 10 条。"
    },
    {
      "key": "pasteBehavior",
      "label": "追加模式",
      "type": "boolean",
      "defaultValue": true,
      "description": "开启后，结果会追加到原文后；关闭则直接替换原文。"
    },
    {
      "key": "enableAIResponseUI",
      "label": "启用 AI 响应 UI",
      "type": "boolean",
      "defaultValue": false,
      "description": "开启后，Gemini 会使用 SwiftBiu 原生 AI 响应弹框展示结果，并支持在弹框中同步修改替换/追加和系统提示词。"
    },
    {
      "key": "responseSystemPrompt",
      "label": "响应 UI 系统提示词",
      "type": "string",
      "defaultValue": "",
      "placeholder": "留空则使用脚本内置默认提示词",
      "description": "AI 响应 UI 中显示和编辑的系统提示词。若需要多套固定提示词，建议复制扩展并分别保存不同版本。"
    }
  ],
  "extensionKind": "textAction"
}
